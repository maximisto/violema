{
  "name": "violema-backend",
  "version": "1.0.0",
  "description": "VIOLEMA backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test VIOLEMA_DISABLE_AUTOMATION_SCHEDULER=1 node --test -r ts-node/register \"tests/**/*.test.ts\" \"tests/**/*.contract.ts\"",
    "test:platform": "NODE_ENV=test VIOLEMA_DISABLE_AUTOMATION_SCHEDULER=1 node --test -r ts-node/register tests/jsonStore.test.ts tests/creditHolds.test.ts",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "composio-core": "^0.5.39",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "node-cron": "^4.2.1",
    "playwright": "^1.52.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "5.3.3"
  }
}
