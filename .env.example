ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PUBLIC_APP_URL=https://violema.com
APP_BASE_URL=https://violema.com
OPENROUTER_SITE_URL=https://violema.com
OPENROUTER_APP_NAME=VIOLEMA
MISTRAL_API_KEY=your_mistral_api_key_here
TAVILY_API_KEY=tvly_your_tavily_api_key_here
POSTMARK_API_KEY=your_postmark_server_api_key_here
POSTMARK_FROM_EMAIL=demo@yourdomain.com
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
# Prefer Slack channel IDs like C0123456789 for automations.
# Optional alias mapping for friendly names:
# SLACK_CHANNEL_OPS_ALERTS=C0123456789
# SLACK_CHANNEL_ALIASES={"#ops-alerts":"C0123456789"}
ADMIN_EMAILS=max@purpleorange.io,max@violema.com
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_SUCCESS_URL=https://violema.com/dashboard?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=https://violema.com/plans?checkout=cancel
STRIPE_CURRENCY=usd
# Expected Stripe subscription products / prices.
# These internal Stripe product keys should stay stable unless you migrate Stripe itself:
# - nexus_starter_monthly
# - nexus_pro_monthly
# - nexus_team_monthly
STRIPE_PRICE_ID_STARTER=price_your_starter_subscription_price_id
STRIPE_PRICE_ID_PRO=price_your_pro_subscription_price_id
STRIPE_PRICE_ID_TEAM=price_your_team_subscription_price_id
# Expected Stripe one-time top-up products / prices.
# These internal Stripe product keys should stay stable unless you migrate Stripe itself:
# - nexus_topup_500
# - nexus_topup_1500
# - nexus_topup_5000
STRIPE_TOP_UP_PRICE_ID_TOPUP_500=price_your_topup_500_price_id
STRIPE_TOP_UP_PRICE_ID_TOPUP_1500=price_your_topup_1500_price_id
STRIPE_TOP_UP_PRICE_ID_TOPUP_5000=price_your_topup_5000_price_id
MODEL_BALANCED_PROVIDER=anthropic
MODEL_BALANCED_MODEL=claude-sonnet-4-20250514
MODEL_FRONTIER_PROVIDER=anthropic
MODEL_FRONTIER_MODEL=claude-opus-4-1-20250805
MODEL_OPERATIONS_PROVIDER=openrouter
MODEL_OPERATIONS_MODEL=minimax/minimax-m2.7
MODEL_MICRO_PROVIDER=openai
MODEL_MICRO_MODEL=gpt-5.4-nano
MODEL_MICRO_REASONING_EFFORT=minimal
MODEL_DEFAULT_PROVIDER=anthropic
MODEL_DEFAULT_MODEL=claude-sonnet-4-20250514
MODEL_HARD_PROVIDER=openai
MODEL_HARD_MODEL=gpt-5.4
MODEL_HARD_REASONING_EFFORT=medium
MODEL_CRITICAL_PROVIDER=anthropic
