MODEL_UTILITY_PROVIDER=openai
MODEL_UTILITY_MODEL=gpt-5.4-nano
MODEL_UTILITY_REASONING_EFFORT=minimal
MODEL_MEMORY_TEXT_MODEL=mistral-embed
MODEL_MEMORY_CODE_MODEL=codestral-embed
